{
  "version": 2,

  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/api/saju/calculate",
      "dest": "/api/saju/calculate.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/saju/compatibility",
      "dest": "/api/saju/compatibility.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/saju/info/(.*)",
      "dest": "/api/saju/info.py",
      "headers": { "Cache-Control": "public, max-age=86400, s-maxage=86400" }
    },
    {
      "src": "/api/palm/analyze",
      "dest": "/api/palm/analyze.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/daily/?$",
      "dest": "/api/daily/index.py"
    },
    {
      "src": "/daily/(rat|ox|tiger|rabbit|dragon|snake|horse|goat|monkey|rooster|dog|pig)/?",
      "dest": "/api/daily/fortune.py?sign=$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1",
      "headers": { "Cache-Control": "public, max-age=3600, s-maxage=86400" }
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1",
      "headers": { "Cache-Control": "public, max-age=3600, s-maxage=86400" }
    },
    {
      "src": "/2bca540734e04bae846415300b37e465\\.txt$",
      "dest": "/public/2bca540734e04bae846415300b37e465.txt",
      "headers": { "Cache-Control": "public, max-age=2592000" }
    },
    {
      "src": "/robots\\.txt$",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/ads\\.txt$",
      "dest": "/public/ads.txt"
    },
    {
      "src": "/index.html",
      "dest": "/public/index.html",
      "headers": { "Cache-Control": "public, max-age=0, s-maxage=60, must-revalidate" }
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    }
  }
}
